python3 - << 'EOF'
import numpy as np
import matplotlib.pyplot as plt

data = np.load('experiments/Compressor_Trainer/mmfi_compressor_202603032012/rec_ep901.npy')

fig = plt.figure(figsize=(20, 12))
angles = [(0,0,'正面'), (0,90,'侧面'), (90,0,'顶视'), (30,45,'斜视')]
for row, (elev, azim, title) in enumerate(angles):
    for col in range(4):
        pc = data[col]
        ax = fig.add_subplot(4, 4, row*4+col+1, projection='3d')
        ax.scatter(pc[:,0], pc[:,1], pc[:,2], s=3, c=pc[:,2], cmap='viridis')
        if col == 0:
            ax.set_ylabel(title)
        ax.set_xticks([]); ax.set_yticks([]); ax.set_zticks([])
        ax.view_init(elev=elev, azim=azim)

plt.tight_layout()
plt.savefig('rec_ep901.png', dpi=150, bbox_inches='tight')
print("saved: rec_ep901.png")
